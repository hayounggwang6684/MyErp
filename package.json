{
  "name": "sunjin-erp-demo",
  "version": "0.1.0",
  "private": true,
  "description": "Sunjin ERP server and Electron client demo",
  "main": "client/main.js",
  "scripts": {
    "dev": "node --watch --import tsx src/app/server.ts",
    "start": "node --import tsx src/app/server.ts",
    "build": "tsc --noEmit",
    "client:start": "electron .",
    "client:pack": "electron-builder --dir",
    "client:dist": "electron-builder --win nsis"
  },
  "dependencies": {
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.6.1",
    "electron": "^36.2.1",
    "electron-builder": "^26.0.12",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "build": {
    "appId": "com.sherwood.sunjin.erp",
    "productName": "Sunjin ERP",
    "directories": {
      "output": "release"
    },
    "files": [
      "client/**/*",
      "src/web/assets/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
